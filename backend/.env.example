# DesiFriend AI Environment Configuration

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud API Configuration (for Speech-to-Text and Text-to-Speech)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
# Or use service account JSON file path
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
MAX_CONVERSATION_HISTORY=10

# Audio Configuration
AUDIO_OUTPUT_DIR=audio_files
AUDIO_FORMAT=mp3
AUDIO_COMPRESSION_QUALITY=128

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
